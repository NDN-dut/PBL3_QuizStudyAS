@using Microsoft.AspNetCore.Http
@inject IHttpContextAccessor HttpContextAccessor

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - QuizStudyAS</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/QuizStudyAS.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand fw-bold text-primary" asp-area="" asp-controller="Home" asp-action="Index">QuizStudyAS</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">

                    @* --- PHẦN MENU BÊN TRÁI: PHÂN QUYỀN Ở ĐÂY --- *@
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Index">Trang chủ</a>
                        </li>

                        @{
                            // Lấy quyền từ Session
                            var role = HttpContextAccessor.HttpContext.Session.GetString("UserRole");
                        }

                        @if (role == "Admin")
                        {
                            <li class="nav-item">
                                <a class="nav-link text-danger fw-bold" asp-controller="Admin" asp-action="Dashboard">Hệ thống</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="Admin" asp-action="ManageUsers">Người dùng</a>
                            </li>
                        }
                        else if (role == "User")
                        {
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-area="" asp-controller="StudySet" asp-action="Index">
                                    <i class="bi bi-collection-play"></i> Bộ thẻ của tôi
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="Classroom" asp-action="Index">Lớp học</a>
                            </li>
                            <li class="nav-item">
                                <a class=" nav-link text-dark" asp-area="" asp-controller="ClassRoom" asp-action="Index" >Find Class</a>
                            </li>
                        }
                    </ul>

                    @* --- PHẦN ĐĂNG NHẬP/ĐĂNG XUẤT BÊN PHẢI --- *@
                    <ul class="navbar-nav ms-auto align-items-center">
                        @{
                            var currentUserName = HttpContextAccessor.HttpContext.Session.GetString("UserName");
                            var userRole = role; // Fix: define userRole for use below
                        }

                        @if (!string.IsNullOrEmpty(currentUserName))
                        {
                            <li class="nav-item me-3">
                                <span class="badge bg-light text-dark border p-2">
                                    <i class="bi bi-person-circle"></i> @currentUserName (@userRole)
                                </span>
                            </li>
                            <li class="nav-item">
                                <a class="btn btn-outline-danger btn-sm fw-bold" asp-controller="Auth" asp-action="Logout">Đăng xuất</a>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <button class="btn btn-primary fw-bold" data-bs-toggle="modal" data-bs-target="#authModal">
                                    Đăng nhập / Đăng ký
                                </button>
                            </li>
                        }
                            
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
            
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - QuizStudyAS - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>

    <partial name="_AuthModal" />

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
