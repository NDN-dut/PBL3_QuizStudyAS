@{
    ViewData["Title"] = "Dashboard - Tổng quan";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-danger fw-bold">Bảng Điều Khiển Tổng Quan</h2>
        <span class="text-muted"><i class="bi bi-clock"></i> Cập nhật lúc: @DateTime.Now.ToString("dd/MM/yyyy HH:mm")</span>
    </div>

    <!-- Khung chứa các thẻ Card Thống Kê -->
    <div class="row g-4">
        <!-- Thẻ 1: Tổng Người Dùng (Màu Xanh Dương) -->
        <div class="col-md-4">
            <div class="card bg-primary text-white shadow h-100 rounded-3 border-0">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-uppercase fw-bold mb-1 opacity-75">Người dùng hệ thống</h6>
                            <h2 class="display-4 fw-bold mb-0">@ViewBag.TotalUsers</h2>
                        </div>
                        <div>
                            <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" fill="currentColor" class="bi bi-people-fill opacity-50" viewBox="0 0 16 16">
                                <path d="M7 14s-1 0-1-1 1-4 5-4 5 3 5 4-1 1-1 1zm4-6a3 3 0 1 0 0-6 3 3 0 0 0 0 6m-5.784 6A2.238 2.238 0 0 1 5 13c0-1.355.68-2.75 1.936-3.72A6.325 6.325 0 0 0 5 9c-4 0-5 3-5 4s1 1 1 1zM4.5 8a2.5 2.5 0 1 0 0-5 2.5 2.5 0 0 0 0 5" />
                            </svg>
                        </div>
                    </div>
                </div>
                <div class="card-footer bg-transparent border-0 pb-3">
                    <a asp-action="ManageUsers" class="text-white text-decoration-none fw-bold stretched-link">
                        Xem chi tiết &rarr;
                    </a>
                </div>
            </div>
        </div>

        <!-- Thẻ 2: Tổng Bộ Thẻ (Màu Xanh Lá) -->
        <div class="col-md-4">
            <div class="card bg-success text-white shadow h-100 rounded-3 border-0">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-uppercase fw-bold mb-1 opacity-75">Bộ thẻ (StudySets)</h6>
                            <h2 class="display-4 fw-bold mb-0">@ViewBag.TotalStudySets</h2>
                        </div>
                        <div>
                            <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" fill="currentColor" class="bi bi-collection-fill opacity-50" viewBox="0 0 16 16">
                                <path d="M0 13a1.5 1.5 0 0 0 1.5 1.5h13A1.5 1.5 0 0 0 16 13V6a1.5 1.5 0 0 0-1.5-1.5h-13A1.5 1.5 0 0 0 0 6zM2 3a.5.5 0 0 0 .5.5h11a.5.5 0 0 0 0-1h-11A.5.5 0 0 0 2 3m2-2a.5.5 0 0 0 .5.5h7a.5.5 0 0 0 0-1h-7A.5.5 0 0 0 4 1" />
                            </svg>
                        </div>
                    </div>
                </div>
                <div class="card-footer bg-transparent border-0 pb-3">
                    <!-- Tạm thời không gán link vì chưa làm giao diện Quản lý StudySet cho Admin -->
                    <span class="text-white opacity-75 fw-bold">Dữ liệu học tập</span>
                </div>
            </div>
        </div>

        <!-- Thẻ 3: Tổng Lớp Học (Màu Cam) -->
        <div class="col-md-4">
            <div class="card bg-warning text-dark shadow h-100 rounded-3 border-0">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-uppercase fw-bold mb-1 opacity-75">Lớp học hoạt động</h6>
                            <h2 class="display-4 fw-bold mb-0">@ViewBag.TotalClassrooms</h2>
                        </div>
                        <div>
                            <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" fill="currentColor" class="bi bi-easel-fill opacity-50" viewBox="0 0 16 16">
                                <path d="M8.473.337a.5.5 0 0 0-.946 0L6.954 2H2a1 1 0 0 0-1 1v7a1 1 0 0 0 1 1h1.85l-1.323 3.837a.5.5 0 1 0 .946.326L4.908 11H7.5v2.5a.5.5 0 0 0 1 0V11h2.592l1.435 4.163a.5.5 0 0 0 .946-.326L12.15 11H14a1 1 0 0 0 1-1V3a1 1 0 0 0-1-1H9.046z" />
                            </svg>
                        </div>
                    </div>
                </div>
                <div class="card-footer bg-transparent border-0 pb-3">
                    <span class="text-dark opacity-75 fw-bold">Mạng lưới kết nối</span>
                </div>
            </div>
        </div>
    </div>
</div>