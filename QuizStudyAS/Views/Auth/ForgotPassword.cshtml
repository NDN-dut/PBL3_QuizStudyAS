@model QuizStudyAS.ViewModels.ForgotPasswordVM
@{
    ViewData["Title"] = "Quên mật khẩu";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="card shadow-sm border-0 rounded-3">
                <div class="card-header bg-success text-white text-center py-3">
                    <h4 class="mb-0 fw-bold">Khôi phục mật khẩu</h4>
                </div>
                <div class="card-body p-4">

                    @if (ViewBag.Message != null)
                    {
                        <div class="alert alert-info text-center fw-bold">
                            @ViewBag.Message
                        </div>
                    }

                    <p class="text-muted text-center mb-4">Nhập email bạn đã đăng ký, chúng tôi sẽ gửi đường dẫn để đặt lại mật khẩu.</p>

                    <form asp-action="ForgotPassword" method="post">
                        <div class="mb-3">
                            <label class="form-label fw-bold">Địa chỉ Email</label>
                            <input asp-for="Email" class="form-control form-control-lg" placeholder="name@example.com" />
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>

                        <div class="d-grid gap-2 mt-4">
                            <button type="submit" class="btn btn-success btn-lg fw-bold">Gửi Link Khôi Phục</button>
                            <a href="/" class="btn btn-outline-secondary fw-bold">Quay lại trang chủ</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>