@model QuizStudyAS.ViewModels.ResetPasswordVM
@{
    ViewData["Title"] = "Tạo mật khẩu mới";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="card shadow-sm border-0 rounded-3">
                <div class="card-header bg-success text-white text-center py-3">
                    <h4 class="mb-0 fw-bold">Tạo Mật Khẩu Mới</h4>
                </div>
                <div class="card-body p-4">

                    @if (ViewBag.ErrorMessage != null)
                    {
                        <div class="alert alert-danger text-center fw-bold">
                            @ViewBag.ErrorMessage
                        </div>
                    }

                    <p class="text-muted text-center mb-4">Vui lòng nhập mật khẩu mới cho tài khoản của bạn.</p>

                    <form asp-action="ResetPassword" method="post">
                        <!-- Thẻ ẩn này cực kỳ quan trọng, nó giữ token lại để submit ngược về Server -->
                        <input type="hidden" asp-for="Token" />

                        <div class="mb-3">
                            <label class="form-label fw-bold">Mật khẩu mới</label>
                            <input type="password" asp-for="NewPassword" class="form-control form-control-lg" placeholder="Nhập mật khẩu..." />
                            <span asp-validation-for="NewPassword" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Xác nhận mật khẩu</label>
                            <input type="password" asp-for="ConfirmPassword" class="form-control form-control-lg" placeholder="Nhập lại mật khẩu..." />
                            <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                        </div>

                        <div class="d-grid gap-2 mt-4">
                            <button type="submit" class="btn btn-success btn-lg fw-bold">Đổi Mật Khẩu</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>