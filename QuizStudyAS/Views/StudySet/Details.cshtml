@model QuizStudyAS.Models.StudySet

@{
    ViewData["Title"] = "Học: " + Model.Title;
}

<div class="container mt-4 mb-5 max-w-md mx-auto" style="max-width: 800px;">
    
    <div id="study-screen">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h4 class="fw-bold m-0">@Model.Title</h4>
            <span class="badge bg-primary fs-6" id="progress-text">1 / @Model.Flashcards.Count</span>
        </div>

        <div class="progress mb-4" style="height: 10px;">
            <div id="progress-bar" class="progress-bar bg-success" role="progressbar" style="width: 0%;"></div>
        </div>

        <div class="flip-card-container mb-4">
            <div class="flip-card" id="flashcard">
                <div class="flip-card-inner">
                    <div class="flip-card-front shadow-sm border">
                        <div class="card-content" id="card-term">Đang tải...</div>
                        <div class="text-muted small position-absolute bottom-0 mb-3">Click để lật thẻ</div>
                    </div>
                    <div class="flip-card-back shadow-sm border bg-light">
                        <div class="card-content text-success" id="card-def">Đang tải...</div>
                        <div class="text-muted small position-absolute bottom-0 mb-3">Click để lật thẻ</div>
                    </div>
                </div>
            </div>
        </div>

        <div class="d-flex justify-content-center gap-4">
            <button class="btn btn-outline-danger btn-lg px-4 py-3 fw-bold rounded-pill shadow-sm action-btn" id="btn-unknown">
                <i class="bi bi-x-lg"></i> Chưa thuộc
            </button>
            <button class="btn btn-outline-success btn-lg px-4 py-3 fw-bold rounded-pill shadow-sm action-btn" id="btn-known">
                <i class="bi bi-check-lg"></i> Đã thuộc
            </button>
        </div>
    </div>

    <div id="result-screen" style="display: none;" class="text-center py-5">
        <h2 class="fw-bold mb-4">Hoàn thành vòng học! 🎉</h2>
        
        <div class="row justify-content-center mb-5">
            <div class="col-md-5">
                <div class="card border-success border-2 shadow-sm mb-3">
                    <div class="card-body py-4">
                        <h1 class="display-4 text-success fw-bold" id="stat-known">0</h1>
                        <p class="text-muted fw-bold text-uppercase m-0">Thẻ đã thuộc</p>
                    </div>
                </div>
            </div>
            <div class="col-md-5">
                <div class="card border-danger border-2 shadow-sm mb-3">
                    <div class="card-body py-4">
                        <h1 class="display-4 text-danger fw-bold" id="stat-unknown">0</h1>
                        <p class="text-muted fw-bold text-uppercase m-0">Thẻ cần học lại</p>
                    </div>
                </div>
            </div>
        </div>

        <div id="perfect-msg" style="display: none;">
            <h4 class="text-success fw-bold">Tuyệt vời! Bạn đã thuộc 100% bộ thẻ này.</h4>
            <a asp-action="Index" class="btn btn-primary mt-3 px-4">Quay về danh sách</a>
        </div>

        <button class="btn btn-warning btn-lg fw-bold px-5 py-3 shadow" id="btn-study-again">
            <i class="bi bi-arrow-clockwise"></i> Học lại các thẻ chưa thuộc
        </button>
        <a asp-action="Index" class="btn btn-light btn-lg px-4 py-3 border shadow-sm mt-3 d-block w-50 mx-auto">Trở về</a>
    </div>

</div>

<style>
    .flip-card-container {
        perspective: 1000px;
        height: 350px;
        width: 100%;
    }

    .flip-card {
        width: 100%;
        height: 100%;
        cursor: pointer;
    }

    .flip-card-inner {
        position: relative;
        width: 100%;
        height: 100%;
        text-align: center;
        transition: transform 0.6s cubic-bezier(0.4, 0.2, 0.2, 1);
        transform-style: preserve-3d;
    }
    /* Thêm class 'flipped' qua JS để kích hoạt lật */
    .flip-card.flipped .flip-card-inner {
        transform: rotateX(180deg);
    }

    .flip-card-front, .flip-card-back {
        position: absolute;
        width: 100%;
        height: 100%;
        backface-visibility: hidden;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 1rem;
        padding: 2rem;
    }

    .flip-card-back {
        transform: rotateX(180deg);
    }

    .card-content {
        font-size: 1.8rem;
        font-weight: bold;
        white-space: pre-wrap; /* Giữ lại các lần xuống dòng của Textarea */
    }

    .action-btn:hover {
        transform: scale(1.05);
        transition: transform 0.2s;
    }
</style>

@section Scripts {
    <script>
        // 1. Nhận dữ liệu C# truyền xuống và biến thành mảng JavaScript
        const allCards = @Html.Raw(Json.Serialize(Model.Flashcards.Select(f => new { term = f.Term, def = f.Definition })));
        
        let currentDeck = [...allCards]; // Mảng chứa các thẻ ĐANG HỌC ở vòng hiện tại
        let currentIndex = 0;
        let knownCards = [];   // Gom các thẻ đã thuộc
        let unknownCards = []; // Gom các thẻ không thuộc

        // 2. Định vị các UI elements
        const uiCard = document.getElementById('flashcard');
        const uiTerm = document.getElementById('card-term');
        const uiDef = document.getElementById('card-def');
        const uiProgress = document.getElementById('progress-bar');
        const uiProgressText = document.getElementById('progress-text');
        const studyScreen = document.getElementById('study-screen');
        const resultScreen = document.getElementById('result-screen');

        // Khởi tạo ngay khi tải trang
        document.addEventListener('DOMContentLoaded', () => {
            loadCard();
        });

        // Lật thẻ khi Click
        uiCard.addEventListener('click', () => {
            uiCard.classList.toggle('flipped');
        });

        // 3. Hàm tải thẻ lên giao diện
        function loadCard() {
            // Nếu đã học hết vòng hiện tại -> Hiện kết quả
            if (currentIndex >= currentDeck.length) {
                showResults();
                return;
            }

            // Đảm bảo mặt thẻ luôn úp khi hiện thẻ mới
            uiCard.classList.remove('flipped');

            // Gắn chữ (Đợi 150ms để thẻ kịp úp xuống mới đổi chữ)
            setTimeout(() => {
                uiTerm.innerText = currentDeck[currentIndex].term;
                uiDef.innerText = currentDeck[currentIndex].def;
            }, 150);
            
            // Cập nhật thanh tiến độ
            let percent = (currentIndex / currentDeck.length) * 100;
            uiProgress.style.width = percent + '%';
            uiProgressText.innerText = `${currentIndex + 1} / ${currentDeck.length}`;
        }

        // 4. Xử lý khi bấm nút Thuộc / Không thuộc
        function markCard(isKnown) {
            if (isKnown) {
                knownCards.push(currentDeck[currentIndex]);
            } else {
                unknownCards.push(currentDeck[currentIndex]);
            }
            
            currentIndex++;
            loadCard();
        }

        document.getElementById('btn-known').addEventListener('click', () => markCard(true));
        document.getElementById('btn-unknown').addEventListener('click', () => markCard(false));

        // 5. Màn hình Thống kê
        function showResults() {
            studyScreen.style.display = 'none';
            resultScreen.style.display = 'block';
            
            document.getElementById('stat-known').innerText = knownCards.length;
            document.getElementById('stat-unknown').innerText = unknownCards.length;
            
            if (unknownCards.length === 0) {
                document.getElementById('btn-study-again').style.display = 'none';
                document.getElementById('perfect-msg').style.display = 'block';
            } else {
                document.getElementById('btn-study-again').style.display = 'inline-block';
                document.getElementById('perfect-msg').style.display = 'none';
            }
        }

        // 6. Logic thần thánh: Bắt đầu vòng lặp mới chỉ với các thẻ chưa thuộc
        document.getElementById('btn-study-again').addEventListener('click', () => {
            currentDeck = [...unknownCards]; // Gán bộ bài mới bằng các thẻ bị sai
            currentIndex = 0;
            knownCards = [];   // Reset giỏ
            unknownCards = []; // Reset giỏ
            
            resultScreen.style.display = 'none';
            studyScreen.style.display = 'block';
            loadCard();
        });
    </script>
}