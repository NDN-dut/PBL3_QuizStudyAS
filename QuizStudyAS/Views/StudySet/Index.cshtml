@model IEnumerable<QuizStudyAS.Models.StudySet>

@{
    ViewData["Title"] = "Bộ thẻ của tôi";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold">Học phần của bạn</h2>
        <a asp-action="Create" class="btn btn-primary fw-bold">
            <i class="bi bi-plus-lg"></i> Tạo bộ thẻ mới
        </a>
    </div>

    @if (!Model.Any())
    {
        <div class="text-center py-5 shadow-sm bg-light rounded">
            <p class="text-muted fs-5">Bạn chưa có bộ thẻ nào.</p>
            <a asp-action="Create" class="btn btn-outline-primary">Bắt đầu tạo ngay</a>
        </div>
    }
    else
    {
        <div class="row row-cols-1 row-cols-md-3 g-4">
            @foreach (var item in Model)
            {
                <div class="col">
                    <div class="card h-100 border-0 shadow-sm hover-shadow transition">
                        <div class="card-body">
                            <h5 class="card-title fw-bold">@item.Title</h5>
                            <p class="card-text text-muted small">@item.Flashcards.Count thẻ | Tạo ngày @item.CreatedAt.ToString("dd/MM/yyyy")</p>
                            <p class="text-truncate">@item.Description</p>
                        </div>
                        <div class="card-footer bg-white border-0 pb-3">
                            <div class="d-flex gap-2">
                                <a asp-action="Details" asp-route-id="@item.StudySetId" class="btn btn-sm btn-outline-dark flex-grow-1">Học</a>
                                <a asp-action="Edit" asp-route-id="@item.StudySetId" class="btn btn-sm btn-warning">Sửa</a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

<style>
    .hover-shadow:hover {
        transform: translateY(-5px);
        box-shadow: 0 .5rem 1rem rgba(0,0,0,.15) !important;
    }

    .transition {
        transition: all 0.3s ease;
    }
</style>
